	"item": [
		{
			"name": "Get Access token (JWT)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"id": "c7e5b824-6d5a-42dd-953e-92e67ab50123",
						"exec": [
							"// ===== Salesforce JWT Bearer Flow - Pre-request Script =====",
							"// Uses jsrsasign to sign a JWT with RS256 for the JWT Bearer grant type.",
							"// Required environment/collection variables:",
							"//   - clientId      : Salesforce Connected App Consumer Key",
							"//   - salesforceUser: Salesforce username (sub claim)",
							"//   - privateKey    : RSA private key in PEM format (-----BEGIN RSA PRIVATE KEY-----)",
							"//   - audience      : (optional) defaults to https://login.salesforce.com",
							"",
							"const navigator = {}; // jsrsasign workaround",
							"const window = {};    // jsrsasign workaround",
							"",
							"// Load jsrsasign from CDN",
							"pm.sendRequest(",
							"   \"https://kjur.github.io/jsrsasign/jsrsasign-latest-all-min.js\",",
							"    function (err, res) {",
							"        if (err) {",
							"           console.error(\"Failed to load jsrsasign:\", err);",
							"           return;",
							"       }",
							"",
							"        eval(res.text());",
							"",
							"        const clientId    = pm.environment.get(\"clientId\")       || pm.collectionVariables.get(\"clientId\");",
							"        const username    = pm.environment.get(\"salesforceUser\") || pm.collectionVariables.get(\"salesforceUser\");",
							"        const privateKey  = pm.environment.get(\"privateKey\")     || pm.collectionVariables.get(\"privateKey\");",
							"        const audience    = pm.environment.get(\"audience\")       || pm.collectionVariables.get(\"audience\") || \"https://login.salesforce.com\";",
							"",
							"        if (!clientId || !username || !privateKey) {",
							"            console.error(\"Missing required variables: clientId, salesforceUser, or privateKey\");",
							"            return;",
							"        }",
							"",
							"        const now = Math.floor(Date.now() / 1000);",
							"",
							"        const header = {",
							"            alg: \"RS256\",",
							"            typ: \"JWT\"",
							"        };",
							"",
							"        const payload = {",
							"            iss: clientId,",
							"            sub: username,",
							"            aud: audience,",
							"            exp: now + 300  // 5 minutes from now",
							"        };",
							"",
							"        try {",
							"            const key = KEYUTIL.getKey(privateKey);",
							"            const jwt = KJUR.jws.JWS.sign(",
							"                \"RS256\",",
							"                JSON.stringify(header),",
							"                JSON.stringify(payload),",
							"                key",
							"            );",
							"",
							"            pm.variables.set(\"jwt_token\", jwt);",
							"            console.log(\"JWT generated successfully and stored in jwt_token variable.\");",
							"        } catch (e) {",
							"            console.error(\"Error signing JWT:\", e);",
							"        }",
							"    }",
							");"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "test",
					"script": {
						"id": "bfe75221-4238-4843-8425-362c75c49d05",
						"exec": [
							"var responseXML = xml2Json(pm.response.text());\r",
							"\r",
							"// Test the response status code\r",
							"pm.test(\"Response status code is 200\", function () {\r",
							"  pm.response.to.have.status(200);\r",
							"});\r",
							"\r",
							"// Test response time\r",
							"pm.test(\"Response time is less than 200ms\", function () {\r",
							"  pm.expect(pm.response.responseTime).to.be.below(200);\r",
							"});\r",
							"\r",
							"// Validate response schema\r",
							"pm.test(\"Schema is valid\", function () {\r",
							"  var schema = {\r",
							"    type: \"object\",\r",
							"    properties: {\r",
							"      // Define expected properties here\r",
							"    },\r",
							"    required: [] // Add required properties if any\r",
							"  };\r",
							"\r",
							"  pm.expect(tv4.validate(responseXML, schema)).to.be.true;\r",
							"});\r",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
